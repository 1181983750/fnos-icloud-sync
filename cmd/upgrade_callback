#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"

mkdir -p "${TRIM_PKGVAR}/config" 2>/dev/null || true
for script in main config_init config_callback install_init install_callback upgrade_init upgrade_callback uninstall_init uninstall_callback; do
    chmod +x "${SCRIPT_DIR}/${script}" 2>/dev/null || true
done
chmod +x "${TRIM_APPDEST}/ui/index.cgi" 2>/dev/null || true
exit 0
