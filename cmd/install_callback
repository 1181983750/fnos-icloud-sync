#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"

mkdir -p "${TRIM_PKGVAR}/config" "${TRIM_PKGVAR}/logs"
for script in main config_init config_callback install_init install_callback upgrade_init upgrade_callback uninstall_init uninstall_callback; do
    chmod +x "${SCRIPT_DIR}/${script}" 2>/dev/null || true
done
chmod +x "${TRIM_APPDEST}/ui/index.cgi" 2>/dev/null || true

mkdir -p "/var/apps/${TRIM_APPNAME}/shares/icloud/photos" \
         "/var/apps/${TRIM_APPNAME}/shares/icloud/videos" \
         "/var/apps/${TRIM_APPNAME}/shares/icloud/notes"

json_bool() {
    if [ "$1" = "true" ]; then
        printf "true"
    else
        printf "false"
    fi
}

CONFIG_FILE="${TRIM_PKGVAR}/config/config.json"
STATE_FILE="${TRIM_PKGVAR}/config/state.json"

if [ ! -f "${CONFIG_FILE}" ]; then
    photos_enabled="$(json_bool "${wizard_enable_photos:-true}")"
    videos_enabled="$(json_bool "${wizard_enable_videos:-true}")"
    notes_enabled="$(json_bool "${wizard_enable_notes:-false}")"

    cat > "${CONFIG_FILE}" <<EOF
{
  "schema_version": 2,
  "active_profile_id": "default",
  "profiles": [
    {
      "id": "default",
      "name": "默认方案",
      "data_subdir": "",
      "apple_id": "",
      "store_password": false,
      "password": "",
      "photos_enabled": ${photos_enabled},
      "videos_enabled": ${videos_enabled},
      "notes_enabled": ${notes_enabled},
      "schedule_enabled": false,
      "sync_interval_minutes": 360,
      "domain": "cn",
      "folder_structure": "{:%Y/%m/%d}",
      "media_mode": "copy",
      "recent": "",
      "until_found": "",
      "album": "",
      "library": "",
      "size": "original",
      "retry_attempts": 3,
      "retry_delay_seconds": 60,
      "include_live_photos": true,
      "keep_unicode": true,
      "set_exif_datetime": true,
      "notes": {
        "host": "imap.mail.me.com",
        "port": 993,
        "username": "",
        "password": "",
        "folder": "Notes",
        "format": "markdown",
        "limit": 0
      }
    }
  ]
}
EOF
fi

if [ ! -f "${STATE_FILE}" ]; then
    cat > "${STATE_FILE}" <<'EOF'
{
  "schema_version": 2,
  "profiles": {
    "default": {
      "last_media_sync": "",
      "last_notes_sync": "",
      "last_scheduler_check": "",
      "last_media_schedule_attempt": "",
      "last_notes_schedule_attempt": "",
      "last_scheduler_trigger": "",
      "scheduler_check_count": 0,
      "scheduler_trigger_count": 0,
      "last_scheduler_status": "",
      "last_scheduler_message": ""
    }
  }
}
EOF
fi

exit 0
