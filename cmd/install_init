#!/bin/bash

set -u

log_error() {
    printf '%s\n' "$1" >&2
}

python_is_312() {
    candidate="$1"
    [ -n "$candidate" ] || return 1
    command -v "$candidate" >/dev/null 2>&1 || return 1

    version="$("$candidate" -c 'import sys; print(f"{sys.version_info[0]}.{sys.version_info[1]}")' 2>/dev/null || true)"
    [ "$version" = "3.12" ] || return 1

    "$candidate" -m venv --help >/dev/null 2>&1 || return 1
    return 0
}

find_python312() {
    if [ -n "${PYTHON_BIN:-}" ] && python_is_312 "$PYTHON_BIN"; then
        command -v "$PYTHON_BIN"
        return 0
    fi

    for candidate in python3.12 /usr/local/bin/python3.12 /usr/bin/python3.12 python3 python; do
        if python_is_312 "$candidate"; then
            command -v "$candidate"
            return 0
        fi
    done
    return 1
}

if python_bin="$(find_python312)"; then
    printf 'Python 3.12 检测通过: %s\n' "$python_bin"
    exit 0
fi

log_error "未检测到可用的 Python 3.12。"
log_error "iCloud 同步内置 wheel 当前面向 Linux x86_64 Python 3.12，安装前请先在系统里安装 python3.12，并确保 python3.12 -m venv 可用。"
log_error "可通过 SSH 执行以下命令自查：python3.12 -V && python3.12 -m venv --help"
exit 1
