#!/bin/bash

LOG_DIR="${TRIM_PKGVAR:-$(cd "$(dirname "$0")/.." 2>/dev/null && pwd)/var}/logs"
mkdir -p "$LOG_DIR" 2>/dev/null || true
LOG_FILE="${LOG_DIR}/config_init.log"

{
    . "$(cd "$(dirname "$0")" 2>/dev/null && pwd)/config_shared.sh"

    load_accessible_paths
    selected_root="$(normalize_selected_root "$(current_selected_root)")"
    write_storage_root_json "$selected_root"
    write_compose_env "$selected_root"
    write_wizard_config "$selected_root"
} >> "$LOG_FILE" 2>&1 || true

exit 0
